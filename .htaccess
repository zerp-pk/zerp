<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    <Files .env>
        Order Allow,Deny
        Deny from all
    </Files>

    RewriteEngine On

    # On shared hosting the app is cloned straight into the document root
    # (public_html), so the backend tree sits under the webroot and is otherwise
    # fetchable: /.git/config exposes the whole source, /storage/logs/laravel.log
    # exposes stack traces. Block it before anything else runs.
    #
    # Deliberately NOT blocked: /packages/... and /storage/media/..., which the
    # rewrite below maps into public/ to serve module and uploaded images.
    RewriteRule ^(\.git|\.github|app|bootstrap|config|database|node_modules|resources|routes|stubs|tests)(/|$) - [F,L]

    # storage/ is two things at once: the backend directory (logs, framework caches,
    # the `installed` marker) AND the /storage/media/... URL prefix for uploaded
    # files, which is not a real path here — it falls through to the rewrite below
    # and lands on public/storage. media/ is the only public prefix; deny the rest.
    RewriteCond %{REQUEST_URI} !^/storage/media/
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|package(-lock)?\.json|artisan|deploy\.sh|phpunit\.xml|docker-compose\.yml|Dockerfile|vite\.config\.js|tailwind\.config\.js|postcss\.config\.js|tsconfig\.json|components\.json|extract-translations\.php|.*\.md)$ - [F,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Handle Front Controller...
    RewriteCond %{REQUEST_URI} !(\.css|\.js|\.png|\.webp|\.jpg|\.jpeg|\.gif|robots\.txt|\.ico|\.woff|\.woff2|.ttf|\.svg|\.pdf|\.doc|\.docx|\.xls|\.xlsx|\.xlsm|\.xlsb|\.xltx|\.xltm|\.xla|\.xlam|\.csv|\.zip|\.mp4|\.mp3)$ [NC]
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(css|assets|market_assets|images|landing|uploads|storage|installer|js|vendor|build|screenshots|packages)/(.*)$ public/$1/$2 [L,NC]
</IfModule>
