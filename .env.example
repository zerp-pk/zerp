# Copy this file to .env before installing:  cp .env.example .env
#
# .env holds your secrets and is never committed. The values here are the
# recommended defaults: safe to run as-is against a local MySQL or Docker, and
# safe to deploy once you have set APP_URL, the DB credentials, and a mail host.
#
# APP_KEY is deliberately empty. `php artisan app:install` generates one, or run
# `php artisan key:generate` yourself. Never share it: it encrypts every session
# and cookie, so anyone holding it can forge a login.

# --- Application ---------------------------------------------------------
APP_NAME=Zerp
# local turns on developer error pages. Leave this as production on a server.
APP_ENV=production
APP_KEY=
# Never true on a public server: it exposes stack traces, config and queries,
# and it is what switches the debug bar on.
APP_DEBUG=false
# The URL the app is served from. Must match, or assets and links break.
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Karachi
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# --- Database ------------------------------------------------------------
# Zerp requires MySQL 8. Docker Compose creates this database and user for you
# and overrides DB_HOST to `db`, so these values work unchanged there.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zerp
DB_USERNAME=zerp
DB_PASSWORD=secret

# --- Session, cache, queue -----------------------------------------------
# database keeps a fresh install to one dependency. Switch to redis under load.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

# --- Logging -------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# debug on a server fills the disk and logs request data. Raise it to debug
# only while chasing something.
LOG_LEVEL=error

# --- Mail ----------------------------------------------------------------
# These are the fallback only. Each company sets its own SMTP in
# Settings > Email, and that takes over for anything it sends.
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Redis ---------------------------------------------------------------
# Only used if you point a driver above at redis. Docker Compose runs one and
# overrides REDIS_HOST to `redis`.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Broadcasting via Pusher ---------------------------------------------
# Only needed if you set BROADCAST_CONNECTION=pusher.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# --- S3 storage ----------------------------------------------------------
# Only needed if you set FILESYSTEM_DISK=s3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Frontend ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
